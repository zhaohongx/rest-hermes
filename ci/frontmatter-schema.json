{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hermes-agent.local/schemas/skill-frontmatter-v1.json",
  "title": "Hermes Agent SKILL.md Frontmatter Schema",
  "description": "Strong-type validation for SKILL.md YAML frontmatter fields.",
  "type": "object",
  "required": ["name", "version", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "maxLength": 64,
      "description": "Skill identifier: lowercase, hyphens, alphanumeric, max 64 chars"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (MAJOR.MINOR.PATCH)"
    },
    "description": {
      "type": "string",
      "maxLength": 1024,
      "description": "One-line trigger + behavior description"
    },
    "enabled_by_default": {
      "type": "boolean",
      "description": "Whether this skill/version is active by default. beta skills set false."
    },
    "toolkit_mode": {
      "enum": ["preview", "active"],
      "description": "Toolkit activation status (for toolkit-mode skills)"
    },
    "fallback_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version to fall back to if this version is disabled"
    },
    "mode": {
      "enum": ["always_on", "on_demand", "toolkit"],
      "description": "Skill execution mode"
    },
    "priority": {
      "enum": ["P-1", "P0", "P1", "P2"],
      "description": "Scheduling priority"
    },
    "output_mode": {
      "enum": ["visible", "hidden", "hybrid"],
      "description": "Output visibility mode"
    },
    "status": {
      "enum": ["active", "beta", "preview", "deprecated", "removed"],
      "description": "Lifecycle status"
    },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "platforms": {
      "type": "array",
      "items": { "type": "string", "enum": ["linux", "macos", "windows"] }
    },
    "trigger": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skip_when": {
      "type": "array",
      "items": { "type": "string" }
    },
    "not_when": {
      "type": "array",
      "items": { "type": "string" }
    },
    "invoke_when": {
      "type": "array",
      "items": { "type": "string" }
    },
    "force_skip_categories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "exposed_tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "description": { "type": "string" },
          "input": { "type": "string" },
          "output": { "type": "string" },
          "latency_target_ms": { "type": "integer", "minimum": 1 },
          "contract": { "type": "string" }
        }
      }
    },
    "pipelines": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["steps"],
        "properties": {
          "description": { "type": "string" },
          "steps": { "type": "array", "items": { "type": "string" } },
          "parallel": { "type": "array", "items": { "type": "string" } },
          "cost": { "type": "string" },
          "equivalent_to": { "type": "string" }
        }
      }
    },
    "reference_loading_policy": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "fallback_strategy": {
      "type": "object",
      "properties": {
        "on_timeout": { "type": "string" },
        "on_low_confidence": { "type": "string" }
      }
    },
    "llm_fallback": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "model_tier": { "enum": ["lightweight", "standard", "heavy"] },
        "max_fallback_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "latency_budget_ms": { "type": "integer", "minimum": 1 },
    "token_budget": { "type": "integer", "minimum": 1 },
    "cost_tier": { "enum": ["low", "medium", "high"] },
    "metadata": {
      "type": "object",
      "properties": {
        "hermes": {
          "type": "object",
          "properties": {
            "tags": { "type": "array", "items": { "type": "string" } },
            "related_skills": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "beta": {
      "type": "object",
      "required": ["start_date", "evaluation_date", "hard_deadline"],
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "evaluation_date": { "type": "string", "format": "date" },
        "hard_deadline": { "type": "string", "format": "date" },
        "promote_criteria": { "type": "array", "items": { "type": "string" } },
        "rollback_trigger": { "type": "array", "items": { "type": "string" } },
        "activation": {
          "type": "object",
          "properties": {
            "input_prefix": { "type": "array", "items": { "type": "string" } },
            "whitelist": { "type": "string" }
          }
        }
      }
    },
    "deprecation": {
      "type": "object",
      "properties": {
        "status": { "enum": ["stable", "deprecated", "removed"] },
        "remove_in": { "type": "string" },
        "next_major": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "next_major_status": { "enum": ["active", "beta", "preview"] },
        "replacement": { "type": "string" }
      }
    },
    "deprecation_notice": {
      "type": "object",
      "properties": {
        "status": { "enum": ["active", "deprecated", "removed"] },
        "supported_until": { "type": "string", "format": "date" },
        "replaced_by": { "type": "string" },
        "migration_guide": { "type": "string" }
      }
    }
  }
}
